KEEPER_PRIVATE_KEY=0x...          # keeper EOA — fund with STT on Somnia testnet
ANTHROPIC_API_KEY=sk-ant-...      # Claude planner + rater

# Database — local dev default (keepers + SSE need this):
TURSO_DB_URL=file:./twiin.db
TURSO_AUTH_TOKEN=

# Remote Turso (production only — keepers fail if this host is unreachable):
# TURSO_DB_URL=libsql://your-db.aws-ap-south-1.turso.io
# TURSO_AUTH_TOKEN=

# Optional
# SOMNIA_RPC_URL=https://dream-rpc.somnia.network/
# PORT=3001
# START_BLOCK=399376700 # Somnia testnet deployment window; set near deploy block to skip historical scan on first boot
# PLAN_SECRET=         # guards POST /api/plan — set same value as VITE_PLAN_SECRET in frontend/.env.local
# TRUST_PROXY=false    # set true when behind a reverse proxy (Render/Railway) to trust X-Forwarded-For
