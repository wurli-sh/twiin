{
  "name": "@twiin/docs-lens",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "dev": "node --env-file-if-exists=../../.env.external-agents.local --env-file-if-exists=../../.env.external-agents --env-file-if-exists=.env.local --env-file-if-exists=.env ./node_modules/tsx/dist/cli.mjs watch src/index.ts",
    "build": "pnpm --filter @twiin/external-kit build && tsc",
    "start": "node --env-file-if-exists=../../.env.external-agents.local --env-file-if-exists=../../.env.external-agents --env-file-if-exists=.env.local --env-file-if-exists=.env dist/src/index.js",
    "test": "vitest run --config vitest.config.ts",
    "register:somnia": "node --env-file-if-exists=../../.env.external-agents.local --env-file-if-exists=../../.env.external-agents --env-file-if-exists=.env.local --env-file-if-exists=.env ./node_modules/tsx/dist/cli.mjs scripts/register.ts",
    "smoke:curl": "bash scripts/smoke-curl.sh"
  },
  "dependencies": {
    "@twiin/external-kit": "workspace:*",
    "@twiin/shared": "workspace:*",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.0",
    "vitest": "^3.2.4"
  }
}
