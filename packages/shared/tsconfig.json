{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "declaration": true,
    "outDir": "dist",
    "rootDir": "."
  },
  "include": ["index.ts", "constants.ts", "digest.ts", "twiin-account.ts", "somnia-agents.ts", "abis/index.ts"],
  "exclude": ["node_modules", "dist", "scripts", "test", "vitest.config.ts"]
}
